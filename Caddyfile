ifp-desk.duckdns.org {
    handle /api/* {
        reverse_proxy backend:8000 {
            header_up X-Real-IP {remote_host}
        }
    }
    handle /health {
        reverse_proxy backend:8000 {
            header_up X-Real-IP {remote_host}
        }
    }
    handle /api/files/* {
        reverse_proxy backend:8000 {
            header_up X-Real-IP {remote_host}
        }
    }
    handle {
        reverse_proxy frontend:3000
    }
}
