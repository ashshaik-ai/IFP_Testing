# Copy to .env on the VM and fill in. .env is gitignored — never commit real values.
# Generate strong values: openssl rand -hex 24
WAHA_API_KEY=
WAHA_DASHBOARD_USERNAME=ifpadmin
WAHA_DASHBOARD_PASSWORD=
# The monitor dashboard basic-auth password is separate; its bcrypt hash goes in the Caddyfile
# (see README). Store the plaintext monitor password in your password manager.
